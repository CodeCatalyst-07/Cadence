# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored — never commit actual credentials.

# IBM Cloud > Manage > Access (IAM) > API keys
# Create a new API key (or copy an existing one) from:
# https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=

# watsonx.ai project ID — open your project in IBM watsonx.ai,
# go to the Manage tab, and copy the Project ID shown there:
# https://dataplatform.cloud.ibm.com/projects
WATSONX_PROJECT_ID=

# Regional REST endpoint for the region where your watsonx.ai project lives.
# Examples:
#   Dallas   (us-south): https://us-south.ml.cloud.ibm.com
#   London   (eu-gb):    https://eu-gb.ml.cloud.ibm.com
#   Frankfurt(eu-de):    https://eu-de.ml.cloud.ibm.com
#   Sydney   (au-syd):   https://au-syd.ml.cloud.ibm.com
# Docs: https://cloud.ibm.com/apidocs/watsonx-ai#endpoint-url
WATSONX_URL=
